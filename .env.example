# FRED (Federal Reserve Economic Data) API Key
# Get one from: https://fred.stlouisfed.org/api_key.html
FRED_API_KEY=your_fred_api_key_here

# FinBERT Sentiment Model Configuration
# Set to 1 to run offline (requires models pre-downloaded)
FINBERT_OFFLINE_ONLY=0

# OpenAI API Key (For GPT-4o models etc.)
# Get one from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (Recommended - free tier available)
# Get one from: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# LLM Provider Configuration (Options: Google, OpenAI)
LLM_PROVIDER=Google
LLM_MODEL_NAME=gemini-2.5-flash

# Financial Datasets MCP Configuration
# Get one from: https://financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=your_financial_datasets_api_key_here
FINANCIAL_DATASETS_URL=https://mcp.financialdatasets.ai/api
